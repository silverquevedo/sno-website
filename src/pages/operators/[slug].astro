---
import Base from '../../layouts/Base.astro';
import { OPERATORS, loreHtmlPath } from '../../data/operators';

export function getStaticPaths() {
  return OPERATORS
    .filter(op => op.slug)
    .map(op => ({ params: { slug: op.slug! }, props: { op } }));
}

const { op } = Astro.props;
const htmlPath = loreHtmlPath(op)!;
---

<Base title={`${op.name} — Silver Night Operator`} description={`Operator ${String(op.id).padStart(2,'0')} · ${op.faction}`}>

  <!-- back bar -->
  <div class="dossier-back">
    <a href="/operators" class="back-link">
      <span class="back-arrow">←</span> Operators
    </a>
    <span class="dossier-meta">
      {String(op.id).padStart(2,'0')} · {op.faction}
    </span>
  </div>

  <!-- dossier embedded -->
  <iframe
    class="dossier-frame"
    src={htmlPath}
    title={`${op.name} dossier`}
    loading="eager"
  ></iframe>

</Base>

<style>
.dossier-back {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem clamp(1rem, 4vw, 3rem);
  border-bottom: 1px solid rgba(0,196,255,0.1);
  background: rgba(9,9,14,0.7);
}

.back-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  transition: color 0.15s;
}
.back-link:hover { color: var(--cyan); }

.back-arrow { font-size: 0.9rem; }

.dossier-meta {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  color: var(--dimmer);
  text-transform: uppercase;
}

.dossier-frame {
  display: block;
  width: 100%;
  height: calc(100vh - var(--nav-h) - 41px); /* full screen minus nav + back bar */
  border: none;
  background: #09090e;
}
</style>
