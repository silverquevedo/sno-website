---
import Base from '../../layouts/Base.astro';
import { OPERATORS, loreHtmlPath, FACTION_COLORS } from '../../data/operators';

export function getStaticPaths() {
  return OPERATORS
    .filter(op => op.slug)
    .map(op => ({ params: { slug: op.slug! }, props: { op } }));
}

const { op } = Astro.props;
const htmlPath = loreHtmlPath(op)!;

// Build ordered list of operators that have dossiers
const dossierOps = OPERATORS.filter(o => o.slug && o.lore);
const idx = dossierOps.findIndex(o => o.slug === op.slug);
const prev = idx > 0 ? dossierOps[idx - 1] : null;
const next = idx < dossierOps.length - 1 ? dossierOps[idx + 1] : null;

const paddedId = String(op.id).padStart(2, '0');
const factionColor = FACTION_COLORS[op.faction] ?? 'var(--dim)';
---

<Base title={`${op.name} — Silver Night Operator`} description={`Operator ${paddedId} · ${op.faction}`}>

  <!-- back bar -->
  <div class="dossier-back">
    <a href="/operators" class="back-link">
      <span class="back-arrow">←</span> Operators
    </a>

    <!-- prev/next navigation -->
    <div class="dossier-nav">
      {prev ? (
        <a href={`/operators/${prev.slug}`} class="nav-chip nav-chip--prev" title={prev.name}>
          <span class="nav-arr">←</span>
          <span class="nav-id">{String(prev.id).padStart(2,'0')}</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-arr">←</span>
          <span class="nav-id">--</span>
        </span>
      )}

      <span class="dossier-meta" style={`color: ${factionColor};`}>
        {paddedId} · {op.name}
      </span>

      {next ? (
        <a href={`/operators/${next.slug}`} class="nav-chip nav-chip--next" title={next.name}>
          <span class="nav-id">{String(next.id).padStart(2,'0')}</span>
          <span class="nav-arr">→</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-id">--</span>
          <span class="nav-arr">→</span>
        </span>
      )}
    </div>

    <!-- audio button -->
    <button id="audio-toggle" class="audio-btn" aria-label="Toggle audio" title="Play track">
      <svg class="audio-icon audio-icon--off" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 7h3l4-4v14l-4-4H3V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        <line x1="14" y1="7" x2="18" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <line x1="18" y1="7" x2="14" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <svg class="audio-icon audio-icon--on" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 7h3l4-4v14l-4-4H3V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        <path d="M14 6.5a5 5 0 010 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M16.5 4a8 8 0 010 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- dossier embedded -->
  <iframe
    class="dossier-frame"
    src={htmlPath}
    title={`${op.name} dossier`}
    loading="eager"
  ></iframe>

</Base>

<style>
/* ─── Back bar ──────────────────────────────────────── */
.dossier-back {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 clamp(1rem, 4vw, 3rem);
  height: 41px;
  border-bottom: 1px solid rgba(0,196,255,0.1);
  background: rgba(9,9,14,0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  gap: 1rem;
}

.back-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--body);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-shrink: 0;
  transition: color 0.15s;
}
.back-link:hover { color: var(--cyan); }
.back-arrow { font-size: 0.9rem; }

/* ─── Centre nav cluster ────────────────────────────── */
.dossier-nav {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  min-width: 0;
}

.dossier-meta {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  white-space: nowrap;
  opacity: 0.85;
}

/* ─── Prev / Next chips ─────────────────────────────── */
.nav-chip {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.18rem 0.55rem;
  border: 1px solid rgba(0,196,255,0.3);
  color: var(--body);
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  white-space: nowrap;
}
.nav-chip:not(.nav-chip--disabled):hover {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.45);
  background: rgba(0,196,255,0.06);
}
.nav-chip--disabled {
  opacity: 0.25;
  cursor: default;
  pointer-events: none;
}
.nav-arr {
  font-size: 0.8rem;
  line-height: 1;
}

/* ─── Audio button ──────────────────────────────────── */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: none;
  border: 1px solid rgba(0,196,255,0.25);
  color: var(--dim);
  cursor: pointer;
  flex-shrink: 0;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  padding: 0;
}
.audio-btn:hover {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.5);
  background: rgba(0,196,255,0.06);
}
.audio-btn.playing {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.5);
}
.audio-icon { width: 16px; height: 16px; }
.audio-icon--on  { display: none; }
.audio-icon--off { display: block; }
.audio-btn.playing .audio-icon--on  { display: block; }
.audio-btn.playing .audio-icon--off { display: none; }

/* ─── Iframe ────────────────────────────────────────── */
.dossier-frame {
  display: block;
  width: 100%;
  height: calc(100vh - var(--nav-h) - 41px);
  border: none;
  background: #09090e;
}

/* ─── Mobile: hide faction detail, keep arrows ──────── */
@media (max-width: 640px) {
  .dossier-meta { display: none; }
  .dossier-back { justify-content: space-between; }
  .dossier-nav { gap: 0.4rem; }
}
</style>

<script define:vars={{ folder: op.folder }}>
  (() => {
    const btn = document.getElementById('audio-toggle');
    const audio = document.getElementById('bg-audio');
    if (!btn || !audio) return;

    let tracks = [];
    let playing = false;

    fetch('/audio-manifest.json')
      .then(r => r.json())
      .then(manifest => {
        const files = manifest[folder] ?? [];
        tracks = files.map(f => '/audio/' + folder + '/' + f);
      })
      .catch(() => {});

    btn.addEventListener('click', () => {
      if (playing) {
        audio.pause();
        btn.classList.remove('playing');
        playing = false;
      } else {
        if (!tracks.length) return;
        const src = tracks[Math.floor(Math.random() * tracks.length)];
        audio.src = src;
        audio.play().then(() => {
          btn.classList.add('playing');
          playing = true;
        }).catch(() => {});
      }
    });

    audio.addEventListener('ended', () => {
      btn.classList.remove('playing');
      playing = false;
    });
  })();
</script>
