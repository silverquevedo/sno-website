---
import Base from '../../layouts/Base.astro';
import { OPERATORS, loreHtmlPath, FACTION_COLORS } from '../../data/operators';

export function getStaticPaths() {
  return OPERATORS
    .filter(op => op.slug)
    .map(op => ({ params: { slug: op.slug! }, props: { op } }));
}

const { op } = Astro.props;
const htmlPath = loreHtmlPath(op)!;

// Build ordered list of operators that have dossiers
const dossierOps = OPERATORS.filter(o => o.slug && o.lore);
const idx = dossierOps.findIndex(o => o.slug === op.slug);
const prev = idx > 0 ? dossierOps[idx - 1] : null;
const next = idx < dossierOps.length - 1 ? dossierOps[idx + 1] : null;

const paddedId = String(op.id).padStart(2, '0');
const factionColor = FACTION_COLORS[op.faction] ?? 'var(--dim)';
---

<Base title={`${op.name} — Silver Night Operator`} description={`Operator ${paddedId} · ${op.faction}`}>

  <!-- back bar -->
  <div class="dossier-back">
    <a href="/operators" class="back-link" id="back-to-grid">
      <span class="back-arrow">←</span> Operators
    </a>

    <!-- prev/next navigation -->
    <div class="dossier-nav">
      {prev ? (
        <a href={`/operators/${prev.slug}`} class="nav-chip nav-chip--prev" title={prev.name}>
          <span class="nav-arr">←</span>
          <span class="nav-id">{String(prev.id).padStart(2,'0')}</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-arr">←</span>
          <span class="nav-id">--</span>
        </span>
      )}

      <span class="dossier-meta" style={`color: ${factionColor};`}>
        {paddedId} · {op.name}
      </span>

      {next ? (
        <a href={`/operators/${next.slug}`} class="nav-chip nav-chip--next" title={next.name}>
          <span class="nav-id">{String(next.id).padStart(2,'0')}</span>
          <span class="nav-arr">→</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-id">--</span>
          <span class="nav-arr">→</span>
        </span>
      )}
    </div>

    <!-- audio -->
    <div class="audio-cluster">
      <span id="track-name" class="track-name"></span>
      <button id="audio-toggle" class="audio-btn" aria-label="Toggle audio" title="Play track">
      <svg class="audio-icon audio-icon--off" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 7h3l4-4v14l-4-4H3V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        <line x1="14" y1="7" x2="18" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <line x1="18" y1="7" x2="14" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <svg class="audio-icon audio-icon--on" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 7h3l4-4v14l-4-4H3V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        <path d="M14 6.5a5 5 0 010 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M16.5 4a8 8 0 010 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </button>
    </div>
  </div>

  <!-- dossier embedded -->
  <iframe
    class="dossier-frame"
    src={htmlPath}
    title={`${op.name} dossier`}
    loading="eager"
  ></iframe>

</Base>

<style>
/* ─── Back bar ──────────────────────────────────────── */
.dossier-back {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 clamp(1rem, 4vw, 3rem);
  height: 41px;
  border-bottom: 1px solid rgba(0,196,255,0.1);
  background: rgba(9,9,14,0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  gap: 1rem;
}

.back-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--body);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-shrink: 0;
  transition: color 0.15s;
}
.back-link:hover { color: var(--cyan); }
.back-arrow { font-size: 0.9rem; }

/* ─── Centre nav cluster ────────────────────────────── */
.dossier-nav {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  min-width: 0;
}

.dossier-meta {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  white-space: nowrap;
  opacity: 0.85;
}

/* ─── Prev / Next chips ─────────────────────────────── */
.nav-chip {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.18rem 0.55rem;
  border: 1px solid rgba(0,196,255,0.3);
  color: var(--body);
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  white-space: nowrap;
}
.nav-chip:not(.nav-chip--disabled):hover {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.45);
  background: rgba(0,196,255,0.06);
}
.nav-chip--disabled {
  opacity: 0.25;
  cursor: default;
  pointer-events: none;
}
.nav-arr {
  font-size: 0.8rem;
  line-height: 1;
}

/* ─── Audio cluster ─────────────────────────────────── */
.audio-cluster {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.5rem;
  flex-shrink: 0;
  /* Fixed width reserves space so track name never causes layout shift */
  width: 220px;
}

.track-name {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cyan);
  opacity: 0;
  max-width: 200px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: opacity 0.3s;
}
.track-name.visible { opacity: 0.8; }

/* ─── Audio button ──────────────────────────────────── */
.audio-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: none;
  border: 1px solid rgba(0,196,255,0.25);
  color: var(--dim);
  cursor: pointer;
  flex-shrink: 0;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  padding: 0;
}
.audio-btn:hover {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.5);
  background: rgba(0,196,255,0.06);
}
.audio-btn.playing {
  color: var(--cyan);
  border-color: rgba(0,196,255,0.5);
}
.audio-icon { width: 16px; height: 16px; }
.audio-icon--on  { display: none; }
.audio-icon--off { display: block; }
.audio-btn.playing .audio-icon--on  { display: block; }
.audio-btn.playing .audio-icon--off { display: none; }
@keyframes pulse-hint {
  0%, 100% { border-color: rgba(0,196,255,0.25); }
  50%       { border-color: rgba(0,196,255,0.8); box-shadow: 0 0 8px rgba(0,196,255,0.4); }
}
.audio-btn.pulse-hint { animation: pulse-hint 0.5s ease-in-out 4; }

/* ─── Iframe ────────────────────────────────────────── */
.dossier-frame {
  display: block;
  width: 100%;
  height: calc(100vh - var(--nav-h) - 41px);
  border: none;
  background: #09090e;
}

/* ─── Mobile ─────────────────────────────────────────── */
@media (max-width: 640px) {
  .dossier-meta { display: none; }
  .dossier-back { padding: 0 0.75rem; }
  .dossier-nav { gap: 0.4rem; margin-right: 0; }
  /* On mobile keep audio-cluster in flow, no absolute */
  .audio-cluster {
    position: static;
    transform: none;
    margin-left: auto;
  }
  .track-name { display: none; }
  /* Adjust iframe height for taller back bar */
  .dossier-frame { height: calc(100vh - var(--nav-h) - 70px); }
}
</style>

<script define:vars={{ folder: op.folder }}>
  (() => {
    const btn = document.getElementById('audio-toggle');
    const audio = document.getElementById('bg-audio');
    const trackLabel = document.getElementById('track-name');
    if (!btn || !audio) return;

    let tracks = [];
    let playing = false;
    let currentName = '';

    function formatName(filename) {
      return filename.replace(/\.mp3$/, '').replace(/[-_]/g, ' ');
    }

    function formatDuration(secs) {
      if (!isFinite(secs)) return '';
      const m = Math.floor(secs / 60);
      const s = Math.floor(secs % 60);
      return m + ':' + String(s).padStart(2, '0');
    }

    function updateLabel() {
      if (!trackLabel || !currentName) return;
      const dur = formatDuration(audio.duration);
      trackLabel.textContent = dur ? currentName + '  ' + dur : currentName;
      trackLabel.classList.add('visible');
    }

    function setPlaying(src) {
      const filename = src.split('/').pop() ?? '';
      currentName = formatName(filename);
      audio.src = src;
      audio.play().then(() => {
        btn.classList.add('playing');
        playing = true;
        updateLabel();
      }).catch(() => {
        btn.classList.add('pulse-hint');
        setTimeout(() => btn.classList.remove('pulse-hint'), 2000);
      });
    }

    function stop() {
      audio.pause();
      btn.classList.remove('playing');
      if (trackLabel) { trackLabel.textContent = ''; trackLabel.classList.remove('visible'); }
      playing = false;
    }

    audio.addEventListener('loadedmetadata', () => updateLabel());

    fetch('/audio-manifest.json')
      .then(r => r.json())
      .then(manifest => {
        const files = manifest[folder] ?? [];
        tracks = files.map(f => '/audio/' + folder + '/' + f);
        // Delay autoplay 2s so page render completes before audio fetch starts (LCP)
        if (tracks.length > 0) setTimeout(() => setPlaying(tracks[0]), 2000);
      })
      .catch(() => {});

    btn.addEventListener('click', () => {
      if (playing) {
        stop();
      } else {
        if (!tracks.length) return;
        setPlaying(tracks[0]);
      }
    });

    audio.addEventListener('ended', () => {
      btn.classList.remove('playing');
      if (trackLabel) { trackLabel.textContent = ''; trackLabel.classList.remove('visible'); }
      playing = false;
    });
  })();

  // Save scroll position so /operators restores to the right card on back nav
  document.getElementById('back-to-grid')?.addEventListener('click', () => {
    sessionStorage.setItem('operatorsScrollY', String(window.scrollY));
  });
</script>
