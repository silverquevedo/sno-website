---
import Base from '../../layouts/Base.astro';
import { OPERATORS, loreHtmlPath, FACTION_COLORS } from '../../data/operators';

export function getStaticPaths() {
  return OPERATORS
    .filter(op => op.slug)
    .map(op => ({ params: { slug: op.slug! }, props: { op } }));
}

const { op } = Astro.props;
const htmlPath = loreHtmlPath(op)!;

// Build ordered list of operators that have dossiers
const dossierOps = OPERATORS.filter(o => o.slug && o.lore);
const idx = dossierOps.findIndex(o => o.slug === op.slug);
const prev = idx > 0 ? dossierOps[idx - 1] : null;
const next = idx < dossierOps.length - 1 ? dossierOps[idx + 1] : null;

const paddedId = String(op.id).padStart(2, '0');
const factionColor = FACTION_COLORS[op.faction] ?? 'var(--dim)';
const youtubeId = op.youtube ?? null;
---

<Base title={`${op.name} — Silver Night Operator`} description={`Operator ${paddedId} · ${op.faction}`} footer={false}>

  <!-- back bar -->
  <div class="dossier-back">
    <a href="/operators" class="back-link" id="back-to-grid">
      <span class="back-arrow">←</span> Operators
    </a>

    <!-- prev/next navigation -->
    <div class="dossier-nav">
      {prev ? (
        <a href={`/operators/${prev.slug}`} class="nav-chip nav-chip--prev" title={prev.name}>
          <span class="nav-arr">←</span>
          <span class="nav-id">{String(prev.id).padStart(2,'0')}</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-arr">←</span>
          <span class="nav-id">--</span>
        </span>
      )}

      <span class="dossier-meta" style={`color: ${factionColor};`}>
        {paddedId} · {op.name}
      </span>

      {next ? (
        <a href={`/operators/${next.slug}`} class="nav-chip nav-chip--next" title={next.name}>
          <span class="nav-id">{String(next.id).padStart(2,'0')}</span>
          <span class="nav-arr">→</span>
        </a>
      ) : (
        <span class="nav-chip nav-chip--disabled" aria-hidden="true">
          <span class="nav-id">--</span>
          <span class="nav-arr">→</span>
        </span>
      )}
    </div>

    <!-- mix button -->
    {youtubeId && (
      <button id="yt-toggle" class="mix-btn" aria-label="Play mix on YouTube" title="Play 1-hour mix">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="14" height="14">
          <polygon points="7,4 16,10 7,16" fill="currentColor"/>
        </svg>
        <span>Mix</span>
      </button>
    )}
  </div>

  <!-- floating YouTube mini-player -->
  {youtubeId && (
    <div id="yt-player" class="yt-player" aria-hidden="true">
      <div class="yt-header">
        <span class="yt-label">{op.name}</span>
        <button id="yt-close" class="yt-close" aria-label="Close player">✕</button>
      </div>
      <div class="yt-frame-wrap">
        <iframe
          id="yt-iframe"
          class="yt-iframe"
          src=""
          data-src={`https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0&modestbranding=1`}
          title={`${op.name} mix`}
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  )}

  <!-- dossier embedded -->
  <iframe
    class="dossier-frame"
    src={htmlPath}
    title={`${op.name} dossier`}
    loading="eager"
  ></iframe>

</Base>

<style>
/* ─── Back bar ──────────────────────────────────────── */
.dossier-back {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--page-pad);
  height: 41px;
  border-bottom: 1px solid var(--cyan-10);
  background: var(--bg-glass-85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  gap: 1rem;
}

.back-link {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--body);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-shrink: 0;
  transition: color 0.15s;
}
.back-link:hover { color: var(--cyan); }
.back-link:focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 3px;
}
.back-arrow { font-size: 0.9rem; }

/* ─── Centre nav cluster ────────────────────────────── */
.dossier-nav {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  min-width: 0;
}

.dossier-meta {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  white-space: nowrap;
  opacity: 0.85;
}

/* ─── Prev / Next chips ─────────────────────────────── */
.nav-chip {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: var(--space-1) var(--space-2);
  border: 1px solid var(--cyan-30);
  color: var(--body);
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
  white-space: nowrap;
}
.nav-chip:not(.nav-chip--disabled):hover {
  color: var(--cyan);
  border-color: var(--cyan-40);
  background: var(--cyan-5);
}
.nav-chip:not(.nav-chip--disabled):focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 3px;
  color: var(--cyan);
}
.nav-chip--disabled {
  opacity: 0.25;
  cursor: default;
  pointer-events: none;
}
.nav-arr {
  font-size: 0.8rem;
  line-height: 1;
}

/* ─── Mix button ────────────────────────────────────── */
.mix-btn {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: var(--text-label);
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
  background: none;
  border: 1px solid var(--cyan-25);
  padding: var(--space-1) var(--space-3);
  cursor: pointer;
  flex-shrink: 0;
  transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
}
.mix-btn:hover {
  color: var(--cyan);
  border-color: var(--cyan-50);
  background: var(--cyan-5);
}
.mix-btn.active {
  color: var(--cyan);
  border-color: var(--cyan-50);
}

/* ─── Floating YouTube player ────────────────────────── */
.yt-player {
  position: fixed;
  bottom: var(--space-5);
  right: var(--space-5);
  width: 320px;
  background: var(--bg-lift);
  border: 1px solid var(--cyan-25);
  box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 0 0 1px var(--cyan-8);
  z-index: var(--z-float);
  transform: translateY(120%) scale(0.95);
  opacity: 0;
  transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s ease;
  pointer-events: none;
}
.yt-player.visible {
  transform: translateY(0) scale(1);
  opacity: 1;
  pointer-events: all;
}
.yt-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2) var(--space-3);
  border-bottom: 1px solid var(--cyan-12);
}
.yt-label {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cyan);
  opacity: 0.85;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.yt-close {
  background: none;
  border: none;
  color: var(--dim);
  font-size: 0.75rem;
  cursor: pointer;
  padding: 0.1rem 0.2rem;
  line-height: 1;
  flex-shrink: 0;
  transition: color 0.15s;
}
.yt-close:hover { color: var(--white); }
.yt-frame-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
}
.yt-iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

/* ─── Iframe ────────────────────────────────────────── */
.dossier-frame {
  display: block;
  width: 100%;
  height: calc(100vh - var(--nav-h) - 41px);
  border: none;
  background: var(--bg);
}

/* ─── Mobile ─────────────────────────────────────────── */
@media (max-width: 640px) {
  .dossier-meta {
    flex: 0 0 2.5ch;
    overflow: hidden;
    text-overflow: clip;
    white-space: nowrap;
    letter-spacing: 0;
  }
  .dossier-back { padding: 0 0.75rem; }
  .dossier-nav { gap: 0.4rem; margin-right: 0; }
  .mix-btn span { display: none; }
  .mix-btn { padding: 0.3rem 0.6rem; }
  .yt-player { width: calc(100vw - 2rem); right: 1rem; bottom: 1rem; }
}
</style>

<script>
  (() => {
    const btn = document.getElementById('yt-toggle');
    const player = document.getElementById('yt-player');
    const closeBtn = document.getElementById('yt-close');
    const iframe = document.getElementById('yt-iframe');
    if (!btn || !player || !iframe) return;

    const src = iframe.getAttribute('data-src') ?? '';
    let open = false;

    function show() {
      iframe.setAttribute('src', src);
      player.classList.add('visible');
      player.setAttribute('aria-hidden', 'false');
      btn.classList.add('active');
      open = true;
    }

    function hide() {
      player.classList.remove('visible');
      player.setAttribute('aria-hidden', 'true');
      btn.classList.remove('active');
      iframe.setAttribute('src', '');
      open = false;
    }

    btn.addEventListener('click', () => open ? hide() : show());
    closeBtn?.addEventListener('click', hide);

    // Autoplay on load — small delay so the dossier iframe renders first
    setTimeout(show, 800);
  })();

  // Save scroll position so /operators restores to the right card on back nav
  document.getElementById('back-to-grid')?.addEventListener('click', () => {
    sessionStorage.setItem('operatorsScrollY', String(window.scrollY));
  });
</script>
