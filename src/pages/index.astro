---
import Base from '../layouts/Base.astro';
import { OPERATORS, FACTION_COLORS, FACTION_ORDER, artUrl } from '../data/operators';

const OP_COUNT = OPERATORS.length;

// 3 most recently released operators (highest IDs with dossier + slug)
const INTEL_OPS = OPERATORS
  .filter(op => op.released && op.slug && op.lore)
  .slice(-3)
  .reverse()
  .map(op => ({
    padded: String(op.id).padStart(2, '0'),
    name: op.name,
    slug: op.slug!,
    art: artUrl(op),
    faction: op.faction,
    factionColor: FACTION_COLORS[op.faction] ?? '#9e9c94',
    status: op.faction === 'The Ghost Layer' ? 'GHOST' : 'ACTIVE',
  }));

const FACTION_DESCS: Record<string, string> = {
  'The Architecture':   'They build the rules. They control the flows. Invisible in power.',
  'The Ritual Network': 'Operate where data becomes ritual. The bridge between the digital and the ancient.',
  'South Bloc':         'Cultural resistance from the south. Stronger than any official map shows.',
  'Iron North':         "Absolute discipline. Calculated cold. They don't negotiate.",
  'The Ghost Layer':    "No official record. No fixed territory. They exist because no one can prove they don't.",
  'Forbidden Zone':     'Banned on every official map. Active on every map that matters.',
  'The Velocity':       "The city in motion. Chaos with direction. You can't keep up.",
  'Unaligned':          'No faction. No network. Operate alone. The most dangerous or the most free. Depends on who you ask.',
};
const FACTIONS = FACTION_ORDER.map(name => ({
  name,
  desc: FACTION_DESCS[name] ?? '',
  color: FACTION_COLORS[name] ?? 'var(--dim)',
}));
---

<Base
  title="Silver Night Operator"
  description="28 Operators. 8 Factions. One Megacity."
>

<!-- ═══ § 1 — ACTIVE TRANSMISSION ════════════════════════════ -->
<section class="hero" aria-label="Active transmission">
  <div class="hero-scan" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- Terminal intercept line -->
    <div class="intercept-bar" aria-label="Frequency SNO-001, signal active, classified">
      <span class="intercept-arrow" aria-hidden="true">▸</span>
      <span class="intercept-text" aria-hidden="true">FREQUENCY SNO-001 · SIGNAL ACTIVE · CLASSIFIED</span>
    </div>

    <!-- Neon title -->
    <h1 class="hero-title">
      <span class="t1">Silver Night</span>
      <span class="t2">Operator</span>
    </h1>

    <!-- Field report tagline -->
    <p class="hero-tagline">
      28 transmissions logged.<br/>
      The megacity doesn't know yet.
    </p>

    <!-- Live broadcast indicator -->
    <div class="broadcast-bar" role="status" aria-label="Transmission in progress, 24/7, megacity broadcast">
      <span class="broadcast-dot" aria-hidden="true"></span>
      <span class="broadcast-label">TRANSMISSION IN PROGRESS</span>
      <span class="broadcast-sep" aria-hidden="true">·</span>
      <span class="broadcast-freq">24/7 · MEGACITY BROADCAST</span>
    </div>

    <!-- CTAs -->
    <nav class="hero-cta" aria-label="Primary actions">
      <a href="/operators" class="cta-btn cta-primary">→ Access the archive</a>
      <a
        href="https://www.youtube.com/@silvernightoperator"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn cta-secondary"
      >▷ Listen live</a>
    </nav>

  </div>
</section>

<!-- ═══ § 2 — OPERATIONAL CONTEXT ════════════════════════════ -->
<section class="context" aria-labelledby="context-hdr">
  <div class="section-inner">
    <div class="context-label" id="context-hdr" aria-hidden="true">OPERATIONAL CONTEXT</div>
    <div class="context-layout">
      <div class="context-stat" aria-hidden="true">
        <div class="context-count">{OP_COUNT}</div>
        <div class="context-count-sub">Transmissions<br/>completed.</div>
      </div>
      <div class="context-body">
        <p>A megacity. Eight factions. Territory divided by power, ritual, velocity and blood.</p>
        <p>Silver Night Operator moves between all of them. No permanent allegiance. Documenting what is found.</p>
        <p>Each transmission is an operator: a character, a story, one hour of signal.</p>
        <p class="context-emphasis">These are not songs. These are field records.</p>
        <p>The signal continues.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ § 3 — FACTIONS ════════════════════════════════════════ -->
<section class="factions" aria-labelledby="factions-hdr">
  <div class="section-inner">
    <header class="section-hdr">
      <h2 class="section-label" id="factions-hdr">FIELD INTELLIGENCE — ACTIVE FACTIONS</h2>
      <div class="section-line" aria-hidden="true"></div>
      <span class="section-meta">8 FACTIONS · 1 MEGACITY</span>
    </header>

    <div class="factions-grid" role="list">
      {FACTIONS.map(f => (
        <a
          class="faction-card"
          style={`--accent: ${f.color}`}
          role="listitem"
          href={`/operators?faction=${encodeURIComponent(f.name)}`}
          aria-label={`${f.name} — view operators`}
        >
          <span class="faction-dot" aria-hidden="true"></span>
          <div class="faction-name">{f.name}</div>
          <p class="faction-desc">{f.desc}</p>
          <span class="faction-cta" aria-hidden="true">→ View operators</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══ § 4 — LATEST TRANSMISSIONS ═══════════════════════════ -->
<section class="intel" aria-labelledby="intel-hdr">
  <div class="section-inner">
    <header class="section-hdr">
      <h2 class="section-label" id="intel-hdr">LATEST TRANSMISSIONS</h2>
      <div class="section-line" aria-hidden="true"></div>
      <a href="/operators" class="section-link">View all operators →</a>
    </header>

    <div class="intel-grid">
      {INTEL_OPS.map(op => (
        <a href={`/operators/${op.slug}`} class="intel-file">
          <div class="intel-ghost-num" aria-hidden="true">{op.padded}</div>

          <div class="intel-art">
            <img
              src={op.art}
              alt={`${op.name} operator album art`}
              loading="lazy"
              width="400"
              height="400"
            />
          </div>

          <div class="intel-body">
            <span class="intel-id">OPERATOR {op.padded}</span>
            <div class="intel-name">{op.name}</div>
            <div class="intel-faction" style={`color: ${op.factionColor}`}>{op.faction}</div>
            <div class={`intel-status intel-status--${op.status.toLowerCase()}`}>
              STATUS: {op.status}
            </div>
            <span class="intel-cta-link">→ Open file</span>
          </div>
        </a>
      ))}
    </div>

    <div class="intel-footer">
      <a href="/operators" class="intel-all-link">View all operators →</a>
    </div>
  </div>
</section>

<!-- ═══ § 5 — BROADCAST CHANNELS ════════════════════════════ -->
<section class="channels" aria-labelledby="channels-hdr">
  <div class="section-inner">
    <header class="section-hdr">
      <h2 class="section-label" id="channels-hdr">BROADCAST CHANNELS</h2>
      <div class="section-line" aria-hidden="true"></div>
    </header>

    <div class="channels-grid">
      <a
        href="https://silvernightoperator.bandcamp.com"
        target="_blank"
        rel="noopener noreferrer"
        class="channel-tile"
        aria-label="Bandcamp — silvernightoperator.bandcamp.com"
      >
        <span class="channel-icon" aria-hidden="true">◈</span>
        <div class="channel-body">
          <div class="channel-name">Bandcamp</div>
          <div class="channel-desc">High-quality archive files. Full discography.</div>
          <div class="channel-url">silvernightoperator.bandcamp.com</div>
        </div>
      </a>

      <a
        href="https://www.youtube.com/@silvernightoperator"
        target="_blank"
        rel="noopener noreferrer"
        class="channel-tile"
        aria-label="YouTube — youtube.com/@silvernightoperator"
      >
        <span class="channel-icon" aria-hidden="true">▷</span>
        <div class="channel-body">
          <div class="channel-name">YouTube</div>
          <div class="channel-desc">1-hour transmissions. 24/7 live stream active.</div>
          <div class="channel-url">youtube.com/@silvernightoperator</div>
        </div>
      </a>

      <a
        href="https://ko-fi.com/silvernightoperator"
        target="_blank"
        rel="noopener noreferrer"
        class="channel-tile"
        aria-label="Ko-fi — ko-fi.com/silvernightoperator"
      >
        <span class="channel-icon" aria-hidden="true">◉</span>
        <div class="channel-body">
          <div class="channel-name">Ko-fi</div>
          <div class="channel-desc">Support the signal. Access exclusive material.</div>
          <div class="channel-url">ko-fi.com/silvernightoperator</div>
        </div>
      </a>
    </div>
  </div>
</section>

</Base>

<script>
// ── Context body typewriter ──────────────────────────────
(() => {
  const body = document.querySelector<HTMLElement>('.context-body');
  if (!body) return;

  const paragraphs = [...body.querySelectorAll<HTMLParagraphElement>('p')];
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth < 640;

  // Reduced motion or mobile: show text in terminal green immediately, no animation
  if (reduceMotion || isMobile) {
    paragraphs.forEach(p => p.classList.add('typed'));
    return;
  }

  // Store original text, clear each paragraph
  const texts = paragraphs.map(p => p.textContent ?? '');
  paragraphs.forEach(p => { p.textContent = ''; });
  body.classList.add('js-typing');

  // Blinking block cursor
  const cursor = document.createElement('span');
  cursor.className = 'cursor';
  cursor.setAttribute('aria-hidden', 'true');

  function typeParagraph(idx: number): void {
    if (idx >= paragraphs.length) {
      cursor.remove();
      return;
    }

    const p = paragraphs[idx];
    const text = texts[idx];
    const isEmphasis = p.classList.contains('context-emphasis');
    const charDelay = isEmphasis ? 25 : 18;
    let i = 0;

    p.classList.add('typing');
    p.appendChild(cursor);

    const iv = setInterval(() => {
      if (i < text.length) {
        p.insertBefore(document.createTextNode(text[i]), cursor);
        i++;
      } else {
        clearInterval(iv);
        p.classList.remove('typing');
        p.classList.add('typed');
        setTimeout(() => typeParagraph(idx + 1), 300);
      }
    }, charDelay);
  }

  // Trigger when section scrolls into view (30% threshold)
  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        typeParagraph(0);
      }
    },
    { threshold: 0.3 }
  );

  observer.observe(body);
})();
</script>

<style>
/* ─── Shared layout shell ───────────────────────────────── */
.section-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--page-pad);
}

.section-hdr {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
}

/* Factions header needs extra separation before the dense grid */
.factions .section-hdr {
  margin-bottom: var(--space-8);
}

.section-label {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--dim);
  white-space: nowrap;
  flex-shrink: 0;
  margin: 0;
}

.section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, var(--cyan-20), transparent);
}

.section-meta {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.16em;
  color: var(--dim);
  white-space: nowrap;
}

.section-link {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.14em;
  color: var(--cyan);
  text-decoration: none;
  flex-shrink: 0;
  opacity: 0.7;
  transition: opacity var(--t-fast);
}
.section-link:hover { opacity: 1; }

/* ─── §1 HERO ───────────────────────────────────────────── */
.hero {
  position: relative;
  min-height: calc(100vh - var(--nav-h));
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* CRT scanlines */
.hero-scan {
  position: absolute; inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 3px,
    rgba(0,196,255,0.010) 3px,
    rgba(0,196,255,0.010) 4px
  );
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1280px;
  margin: 0 auto;
  padding: var(--section-v) clamp(1rem, 6vw, 5rem);
  text-align: center;
}

/* ── Intercept terminal line ─────────────────────────────── */
.intercept-bar {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.18em;
  margin-bottom: var(--space-6);
  animation: fade-up 0.5s cubic-bezier(0.16,1,0.3,1) both;
}

.intercept-arrow {
  color: var(--magenta);
  font-size: 0.8rem;
  flex-shrink: 0;
}

.intercept-text {
  color: var(--cyan);
  overflow: hidden;
  white-space: nowrap;
  display: inline-block;
  width: 0;
  /* "FREQUENCY SNO-001 · SIGNAL ACTIVE · CLASSIFIED" = 46 chars */
  animation:
    typer 2.2s steps(46, end) 0.6s forwards,
    cursor-blink 0.7s step-end 0.6s 5;
  border-right: 1.5px solid var(--cyan);
}

@keyframes typer {
  to { width: 46ch; }
}

@keyframes cursor-blink {
  0%, 100% { border-right-color: var(--cyan); }
  50%       { border-right-color: transparent; }
}

/* ── Neon title ──────────────────────────────────────────── */
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(3.8rem, 13vw, 10rem);
  line-height: 1;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.15s both;
}

.t1, .t2 { display: block; }

.t1 {
  color: var(--neon-white);
  margin-bottom: -0.05em;
  text-shadow:
    0 0 2px var(--neon-white),
    0 0 6px var(--neon-white),
    0 0 14px var(--neon-white),
    0 0 26px var(--cyan-pale),
    0 0 48px var(--cyan-mid),
    0 0 70px rgba(0,196,255,0.55);
  animation: neon-flicker-t1 9s ease-in-out 3s infinite;
  will-change: opacity, text-shadow;
}

.t2 {
  color: var(--cyan-warm);
  text-shadow:
    0 0 2px var(--cyan-pale2),
    0 0 6px var(--cyan-warm),
    0 0 14px var(--cyan),
    0 0 28px var(--cyan-deep),
    0 0 52px rgba(0,180,255,0.6),
    0 0 75px rgba(0,150,220,0.3);
  animation: neon-flicker-t2 12s ease-in-out 6s infinite;
  will-change: opacity, text-shadow;
}

@keyframes neon-flicker-t1 {
  0%,  19%,  21%,  23%,  25%, 100% {
    opacity: 1;
    text-shadow: 0 0 2px var(--neon-white), 0 0 6px var(--neon-white), 0 0 14px var(--neon-white), 0 0 26px var(--cyan-pale), 0 0 48px var(--cyan-mid), 0 0 70px rgba(0,196,255,0.55);
  }
  20%, 22%, 24% { opacity: 0.12; text-shadow: none; }
  60%           { opacity: 0.88; }
}

@keyframes neon-flicker-t2 {
  0%,  34%,  36%,  75%, 100% {
    opacity: 1;
    text-shadow: 0 0 2px var(--cyan-pale2), 0 0 6px var(--cyan-warm), 0 0 14px var(--cyan), 0 0 28px var(--cyan-deep), 0 0 52px rgba(0,180,255,0.6), 0 0 75px rgba(0,150,220,0.3);
  }
  35%  { opacity: 0.08; text-shadow: none; }
  74%  { opacity: 0.82; }
}

/* ── Tagline ─────────────────────────────────────────────── */
.hero-tagline {
  font-family: var(--font-mono);
  font-size: clamp(0.92rem, 1.8vw, 1.1rem);
  letter-spacing: 0.08em;
  color: var(--body);
  max-width: 46ch;
  margin: 0 auto var(--space-6);
  line-height: 1.9;
  animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.25s both;
}

/* ── Live broadcast bar ──────────────────────────────────── */
.broadcast-bar {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.14em;
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--white-7);
  background: var(--bg-glass-35);
  margin-bottom: 2.5rem;
  animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.35s both;
}

.broadcast-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--status-active);
  box-shadow: 0 0 5px var(--status-active), 0 0 10px var(--status-active);
  animation: dot-pulse 2.2s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes dot-pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 5px var(--status-active), 0 0 10px var(--status-active); }
  50%       { opacity: 0.45; box-shadow: 0 0 2px var(--status-active); }
}

.broadcast-label { color: var(--white); font-weight: 400; }
.broadcast-sep   { color: var(--dimmer); }
.broadcast-freq  { color: var(--dim); }

/* ── CTAs ────────────────────────────────────────────────── */
.hero-cta {
  display: flex;
  gap: 0.8rem;
  justify-content: center;
  flex-wrap: wrap;
  animation: fade-up 0.6s cubic-bezier(0.16,1,0.3,1) 0.45s both;
}

.cta-btn {
  font-family: var(--font-mono);
  font-size: var(--text-ui);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.7rem 1.8rem;
  border: 1px solid;
  transition: background var(--t-base), color var(--t-base), box-shadow var(--t-base), border-color var(--t-base);
}

.cta-primary {
  color: var(--bg);
  background: var(--cyan);
  border-color: var(--cyan);
}
.cta-primary:hover {
  background: var(--cyan-bright);
  border-color: var(--cyan-bright);
  box-shadow: 0 0 28px var(--cyan-40);
}
.cta-primary:focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 3px;
}

.cta-secondary {
  color: var(--dim);
  background: transparent;
  border-color: var(--white-12);
}
.cta-secondary:hover {
  color: var(--white);
  border-color: rgba(255,255,255,0.3);
}
.cta-secondary:focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 3px;
}

/* ─── §2 OPERATIONAL CONTEXT ────────────────────────────── */
.context {
  padding: 3.5rem 0 4.5rem;
  border-top: 1px solid var(--cyan-8);
  background: rgba(13,13,23,0.6);
}

.context-label {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--dim);
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--cyan-12);
}

.context-layout {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: var(--space-8);
  align-items: start;
}

.context-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-3);
  padding-right: var(--space-8);
  border-right: 1px solid var(--cyan-12);
}

.context-count {
  font-family: var(--font-display);
  font-size: clamp(6rem, 12vw, 10rem);
  line-height: 0.85;
  color: var(--cyan);
  letter-spacing: 0.02em;
  text-shadow: 0 0 40px var(--cyan-50), 0 0 80px rgba(0,196,255,0.2);
  display: block;
}

.context-count-sub {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--dimmer);
  line-height: 1.5;
}

.context-body {
  max-width: 62ch;
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.context-body p {
  font-family: var(--font-mono);
  font-size: 0.88rem;
  line-height: 1.8;
  letter-spacing: 0.02em;
  color: var(--dim);
}

.context-emphasis {
  font-family: var(--font-mono);
  font-size: clamp(1rem, 2vw, 1.25rem) !important;
  letter-spacing: 0.04em !important;
  line-height: 1.5 !important;
  color: var(--white) !important;
  font-style: normal !important;
  margin: var(--space-2) 0;
}

@media (max-width: 640px) {
  .context-layout {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  .context-stat {
    flex-direction: row;
    align-items: baseline;
    gap: var(--space-4);
    border-right: none;
    padding-right: 0;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--cyan-12);
  }
}

/* ─── §3 FACTIONS ────────────────────────────────────────── */
.factions {
  padding: 6rem 0;
  border-top: 1px solid var(--cyan-8);
  border-bottom: 1px solid var(--cyan-8);
  background: rgba(13,13,23,0.5);
}

.factions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--white-3);
}

@media (max-width: 900px) {
  .factions-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 480px) {
  .factions-grid { grid-template-columns: 1fr; }
}

.faction-card {
  display: block;
  background: var(--bg-card);
  padding: var(--space-6) var(--space-5) var(--space-6);
  position: relative;
  transition: background var(--t-base);
  text-decoration: none;
}

.faction-card:focus-visible {
  outline: 2px solid var(--accent, var(--cyan));
  outline-offset: -2px;
}

.faction-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent);
  opacity: 0.5;
  transition: opacity var(--t-base);
}

.faction-card:hover::before { opacity: 1; }
.faction-card:hover {
  background: color-mix(in srgb, var(--accent) 5%, var(--bg-card));
}

.faction-dot {
