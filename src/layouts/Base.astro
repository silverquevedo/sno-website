---
import '../styles/global.css';
import { SITE_URL } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** false hides the site footer — used by full-viewport pages like the dossier */
  footer?: boolean;
}

const {
  title = 'Silver Night Operator',
  description = '28 Operators. 8 Factions. One Megacity.',
  ogImage = '/og-default.png',
  footer = true,
} = Astro.props;

const year = new Date().getFullYear();

const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const ogImageURL = new URL(ogImage, SITE_URL);
const ogTitle = title.includes('Silver Night Operator') ? title : `${title} · Silver Night Operator`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:site_name" content="Silver Night Operator" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" href="/favicon.ico" />
  <link rel="manifest" href="/manifest.json" />

  <!-- Fonts: preload Bebas Neue (hero text), then load all -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=optional"
    rel="stylesheet"
  />

  <slot name="head" />

</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- Navigation -->
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a class="nav-logo" href="/">
        <span class="nav-logo-dot"></span>
        <span class="nav-logo-text">SNO</span>
      </a>
      <div class="nav-links">
        <a class="nav-link" href="/" data-page="home">Home</a>
        <a class="nav-link" href="/operators" data-page="operators">Operators</a>
        <a class="nav-link" href="/factions" data-page="factions">Factions</a>
      </div>
      <div class="nav-external">
        <a href="https://silvernightoperator.bandcamp.com" target="_blank" rel="noopener" class="nav-ext">Bandcamp</a>
        <a href="https://www.youtube.com/@silvernightoperator" target="_blank" rel="noopener" class="nav-ext">YouTube</a>
        <a href="https://ko-fi.com/silvernightoperator" target="_blank" rel="noopener" class="nav-ext">Ko-fi</a>
      </div>
    </div>
  </nav>

  <main id="main-content">
  <slot />
  </main>

  {footer && (
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-sig">
          <span class="footer-dot" aria-hidden="true"></span>
          <span class="footer-brand">SNO · Silver Night Operator</span>
        </div>
        <span class="footer-tag" aria-hidden="true">The signal continues.</span>
        <div class="footer-links">
          <a href="https://silvernightoperator.bandcamp.com" target="_blank" rel="noopener" class="footer-link">Bandcamp</a>
          <a href="https://www.youtube.com/@silvernightoperator" target="_blank" rel="noopener" class="footer-link">YouTube</a>
          <a href="https://ko-fi.com/silvernightoperator" target="_blank" rel="noopener" class="footer-link">Ko-fi</a>
          <span class="footer-year">© {year}</span>
        </div>
      </div>
    </footer>
  )}

  <!-- Audio player -->
  <audio id="bg-audio" preload="none"></audio>
  <script>
    // Audio is handled per-dossier in [slug].astro
  </script>
</body>
</html>

<style is:global>
/* ─── Skip link ──────────────────────────────────────────── */
.skip-link {
  position: absolute;
  top: -100%;
  left: 1rem;
  z-index: var(--z-skip);
  background: var(--bg, #09090e);
  color: var(--cyan, #00c4ff);
  padding: 0.5rem 1rem;
  font-family: monospace;
  font-size: 0.8rem;
  border: 1px solid currentColor;
  text-decoration: none;
  transition: top 0.1s;
}
.skip-link:focus { top: 1rem; }

/* ─── Nav ────────────────────────────────────────────────── */
.site-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  z-index: var(--z-nav);
  background: var(--bg-glass-92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--cyan-10);
}

.site-nav::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,196,255,0.4) 30%, rgba(0,196,255,0.4) 70%, transparent);
  opacity: 0;
  animation: nav-line-in 0.8s ease 0.3s forwards;
}

@keyframes nav-line-in {
  from { opacity: 0; transform: scaleX(0.3); }
  to   { opacity: 1; transform: scaleX(1); }
}

.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 2rem;
  padding: 0 var(--page-pad);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  text-decoration: none;
  flex-shrink: 0;
  margin-right: 0.5rem;
}

.nav-logo-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 6px var(--cyan), 0 0 14px var(--cyan);
  animation: dot-pulse 3s ease-in-out 1s infinite;
}

@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 6px var(--cyan), 0 0 14px var(--cyan); }
  50%       { box-shadow: 0 0 10px var(--cyan), 0 0 28px var(--cyan), 0 0 40px var(--cyan); }
}

.nav-logo-text {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: var(--white);
  text-transform: uppercase;
}

.nav-links {
  display: flex;
  gap: 0.2rem;
}

.nav-link {
  font-family: var(--font-mono);
  font-size: var(--text-ui);
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  padding: var(--space-2) 0.9rem;
  border-bottom: 2px solid transparent;
  transition: color var(--t-fast), border-color var(--t-fast);
}

.nav-link:hover {
  color: var(--white);
  border-bottom-color: var(--cyan-30);
}

.nav-link.is-active {
  color: var(--cyan);
  border-bottom-color: var(--cyan);
}

.nav-external {
  margin-left: auto;
  display: flex;
  gap: 0.2rem;
}

.nav-ext {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  padding: var(--space-2) var(--space-3);
  transition: color var(--t-fast);
}

.nav-ext:hover { color: var(--cyan); }


@media (max-width: 600px) {
  .nav-external { display: none; }
}

/* ─── Footer ─────────────────────────────────────────────── */
.site-footer {
  border-top: 1px solid var(--cyan-10);
  background: var(--bg-glass-60);
}

.footer-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: var(--space-5) var(--page-pad);
  display: flex;
  align-items: center;
  gap: var(--space-5);
  flex-wrap: wrap;
}

.footer-sig {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.footer-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 5px var(--cyan), 0 0 10px var(--cyan-30);
  flex-shrink: 0;
}

.footer-brand {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--dim);
}

.footer-tag {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--dimmer);
}

.footer-links {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.footer-link {
  font-family: var(--font-mono);
  font-size: var(--text-label);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  transition: color var(--t-fast);
}
.footer-link:hover { color: var(--cyan); }

.footer-year {
  font-family: var(--font-mono);
  font-size: var(--text-micro);
  letter-spacing: 0.14em;
  color: var(--dimmer);
}

@media (max-width: 640px) {
  .footer-inner {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .footer-links { margin-left: 0; }
}

/* ─── Mobile perf: disable expensive blur on low-end devices ── */
@media (max-width: 768px) {
  .site-nav {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: var(--bg-glass-97);
  }
}
</style>

<script>
// Highlight active nav link based on current page
const path = window.location.pathname;
document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
  const href = link.getAttribute('href') ?? '';
  const isActive = href === '/'
    ? path === '/'
    : path.startsWith(href);
  link.classList.toggle('is-active', isActive);
});
</script>
