---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Silver Night Operator',
  description = '28 Operators. 8 Factions. One Megacity.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

</head>
<body>
  <!-- Navigation -->
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a class="nav-logo" href="/">
        <span class="nav-logo-dot"></span>
        <span class="nav-logo-text">SNO</span>
      </a>
      <div class="nav-links">
        <a class="nav-link" href="/" data-page="home">Home</a>
        <a class="nav-link" href="/operators" data-page="operators">Operators</a>
      </div>
      <div class="nav-external">
        <a href="https://silvernightoperator.bandcamp.com" target="_blank" rel="noopener" class="nav-ext">Bandcamp</a>
        <a href="https://www.youtube.com/@silvernightoperator" target="_blank" rel="noopener" class="nav-ext">YouTube</a>
        <a href="https://ko-fi.com/silvernightoperator" target="_blank" rel="noopener" class="nav-ext">Ko-fi</a>
      </div>
    </div>
  </nav>

  <slot />
</body>
</html>

<style is:global>
/* ─── Nav ────────────────────────────────────────────────── */
.site-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  z-index: 200;
  background: rgba(9, 9, 14, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0,196,255,0.1);
}

.site-nav::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,196,255,0.4) 30%, rgba(0,196,255,0.4) 70%, transparent);
  opacity: 0;
  animation: nav-line-in 0.8s ease 0.3s forwards;
}

@keyframes nav-line-in {
  from { opacity: 0; transform: scaleX(0.3); }
  to   { opacity: 1; transform: scaleX(1); }
}

.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 2rem;
  padding: 0 clamp(1rem, 4vw, 3rem);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  text-decoration: none;
  flex-shrink: 0;
  margin-right: 0.5rem;
}

.nav-logo-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 6px var(--cyan), 0 0 14px var(--cyan);
  animation: dot-pulse 3s ease-in-out 1s infinite;
}

@keyframes dot-pulse {
  0%, 100% { box-shadow: 0 0 6px var(--cyan), 0 0 14px var(--cyan); }
  50%       { box-shadow: 0 0 10px var(--cyan), 0 0 28px var(--cyan), 0 0 40px var(--cyan); }
}

.nav-logo-text {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: var(--white);
  text-transform: uppercase;
}

.nav-links {
  display: flex;
  gap: 0.2rem;
}

.nav-link {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  padding: 0.4rem 0.9rem;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}

.nav-link:hover {
  color: var(--white);
  border-bottom-color: rgba(0,196,255,0.3);
}

.nav-link.is-active {
  color: var(--cyan);
  border-bottom-color: var(--cyan);
}

.nav-external {
  margin-left: auto;
  display: flex;
  gap: 0.2rem;
}

.nav-ext {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dim);
  text-decoration: none;
  padding: 0.35rem 0.7rem;
  transition: color 0.15s;
}

.nav-ext:hover { color: var(--cyan); }

@media (max-width: 600px) {
  .nav-external { display: none; }
}
</style>

<script>
// Highlight active nav link based on current page
const path = window.location.pathname;
document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
  const href = link.getAttribute('href') ?? '';
  const isActive = href === '/'
    ? path === '/'
    : path.startsWith(href);
  link.classList.toggle('is-active', isActive);
});
</script>
